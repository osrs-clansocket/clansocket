# NGINX Site Configuration — generated from clansocket.template by deployment/utils/env/template-renderer.js.
# Source-of-truth: deployment/nginx/sites-available/clansocket.template
# Edit the template, then re-render via `npm run nginx:push` (also runs on every `deploy:live`).
# Shared rate-limit zones (general/api/dashboard/conn_limit) + log formats live in /etc/nginx/nginx.conf — do not redefine here.
#
# Hostnames covered: ${DEPLOY_PRIMARY_DOMAIN}, www.${DEPLOY_PRIMARY_DOMAIN} (301 → apex), api.${DEPLOY_PRIMARY_DOMAIN}, ws.${DEPLOY_PRIMARY_DOMAIN}, docs.${DEPLOY_PRIMARY_DOMAIN} (301 → apex)
# Cert must cover all five as SANs (issue via certbot --standalone -d ${DEPLOY_CERT_DOMAIN} -d www.${DEPLOY_CERT_DOMAIN} -d api.${DEPLOY_CERT_DOMAIN} -d ws.${DEPLOY_CERT_DOMAIN} -d docs.${DEPLOY_CERT_DOMAIN})

upstream clansocket_backend {
    server localhost:${DEPLOY_BACKEND_PORT};
    keepalive 32;
}

# ─── Main site — ${DEPLOY_PRIMARY_DOMAIN} ───
# Nginx serves static assets directly from dist/; Node handles /api/* and the SPA shell.
server {
    server_name ${DEPLOY_PRIMARY_DOMAIN};

    access_log /var/log/nginx/${DEPLOY_LOG_PREFIX}_main_access.log security;
    error_log /var/log/nginx/${DEPLOY_LOG_PREFIX}_main_error.log warn;

    client_max_body_size 4m;

    # On-the-fly brotli for proxied responses (HTML from express, JSON from /api, etc.)
    # Static files with pre-compressed `.br` siblings continue to be served via `brotli_static on;` in their location blocks.
    brotli on;
    brotli_comp_level 5;
    brotli_types text/plain text/css text/xml text/html application/javascript application/json application/xml application/xml+rss application/manifest+json image/svg+xml;
    # Disable gzip on proxied responses so brotli filter can claim them. Without this, the shared nginx.conf's `gzip_proxied` setting can wrap proxy responses with gzip before brotli's filter runs.
    gzip_proxied off;

    # Cache open file descriptors — big win for static asset serving
    open_file_cache max=4000 inactive=60s;
    open_file_cache_valid 30s;
    open_file_cache_min_uses 2;
    open_file_cache_errors on;

    # Baseline security headers (inherited by locations that don't override)
    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;

    # ─── Service worker — NEVER cache (updates must propagate immediately) ───
    location = /sw.js {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        gzip_static on;
        brotli_static on;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-cache, no-store, must-revalidate" always;
        add_header Service-Worker-Allowed "/" always;
    }

    # ─── Hashed chunks (Vite output) — immutable, 1 year ───
    location ~* ^/assets/ {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        gzip_static on;
        brotli_static on;
        access_log off;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "public, max-age=31536000, immutable";
    }

    # ─── Fonts — immutable, 1 year ───
    location ~* ^/fonts/ {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        access_log off;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "cross-origin" always;
        add_header Cache-Control "public, max-age=31536000, immutable";
        add_header Access-Control-Allow-Origin "*" always;
    }

    # ─── Per-section CSS (stable filenames, not hashed) — 1 week ───
    location ~* ^/styles/ {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        gzip_static on;
        brotli_static on;
        access_log off;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "public, max-age=604800";
    }

    # ─── OSRS icons / images — long cache but not immutable ───
    location ~* ^/resources/ {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        access_log off;

        # Override the server-level open_file_cache_errors on; for this location only — tile bursts
        # (50-150 webp requests in <1s on a viewport change) can transiently fail FD-open or race the
        # positive-cache window, and the 30s negative cache then holds the 404 for files that exist.
        # Positive cache inherits from the server-level directive.
        open_file_cache_errors off;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "public, max-age=2592000";
    }

    # ─── Root-level static files ───
    location ~* ^/(favicon\.ico|favicon\.svg|robots\.txt|manifest\.json)$ {
        root ${DEPLOY_REMOTE_PATH}/dist;
        try_files $uri =404;
        access_log off;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "public, max-age=86400";
    }

    # ─── Sitemap — dynamically generated by express (queries clan DB for public clans). Exact-match wins over regex/prefix locations. ───
    location = /sitemap.xml {
        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_buffering on;
        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "public, max-age=3600" always;
    }

    # ─── AI chat send — SSE-class. Route doesn't end in /stream so the regex below doesn't catch it; exact-match wins over all prefix/regex locations. ───
    location = /api/ai/chat/send {
        limit_req zone=api burst=40 nodelay;
        limit_conn conn_limit 50;

        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_buffering off;
        proxy_cache off;
        proxy_connect_timeout 10s;
        proxy_read_timeout 24h;
        proxy_send_timeout 24h;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-store" always;
    }

    # ─── SSE streams — long-lived, no buffering. MUST come before /api/ so regex match wins. ───
    # SSE connections are long-lived (24h timeout below). A single user with multiple tabs + navigation churn
    # can hold many concurrent connections, so limits need to be generous compared to short-lived REST endpoints.
    location ~* ^/api/.*/stream(\?|$) {
        limit_req zone=api burst=40 nodelay;
        limit_conn conn_limit 50;

        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_buffering off;
        proxy_cache off;
        proxy_connect_timeout 10s;
        proxy_read_timeout 24h;
        proxy_send_timeout 24h;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-store" always;
    }

    # ─── API — proxy to Node, never cache ───
    location /api/ {
        limit_req zone=api burst=40 nodelay;
        limit_conn conn_limit 20;

        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-store" always;
    }

    # ─── SPA shell — proxy to Node, MUST revalidate ───
    location / {
        limit_req zone=general burst=20 nodelay;
        limit_conn conn_limit 10;

        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;

        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;
        proxy_busy_buffers_size 8k;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        # Compression: brotli only on this proxied surface. nginx core's gzip filter outraces dynamically-loaded ngx_brotli in the body filter chain on stock builds, so gzip wins by default and `brotli on` at server scope (line 26) is effectively dead for text/html here. turning gzip off forces brotli to handle the response.
        gzip off;

        # Security headers for HTML responses. CSP nonce is nginx's $request_id (16 random bytes per request); sub_filter injects the same value into <script> and <link rel="modulepreload"> tags so strict-dynamic propagates trust from the entry chunk to its imports. Vite's SRI integrity= attributes stay intact and byte-verify the responses.
        sub_filter '<script ' '<script nonce="$request_id" ';
        sub_filter '<link rel="modulepreload"' '<link rel="modulepreload" nonce="$request_id"';
        sub_filter_once off;
        sub_filter_types text/html;

        add_header Content-Security-Policy "default-src 'none'; script-src 'nonce-$request_id' 'strict-dynamic'; style-src 'self'; img-src 'self' data: https: https://cdn.discordapp.com; font-src 'self' data:; connect-src 'self' https://${DEPLOY_PRIMARY_DOMAIN} https://api.${DEPLOY_PRIMARY_DOMAIN} wss://ws.${DEPLOY_PRIMARY_DOMAIN} https://www.google-analytics.com https://*.analytics.google.com; worker-src 'self'; manifest-src 'self'; media-src 'self'; object-src 'none'; frame-ancestors 'none'; base-uri 'self'; form-action 'self';" always;
        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header Referrer-Policy "strict-origin-when-cross-origin" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header X-Frame-Options "SAMEORIGIN" always;
        add_header X-Permitted-Cross-Domain-Policies "none" always;
        add_header X-DNS-Prefetch-Control "off" always;
        add_header X-XSS-Protection "0" always;
        add_header Permissions-Policy "accelerometer=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=(), interest-cohort=()" always;
        add_header Cross-Origin-Opener-Policy "same-origin" always;
        add_header Cross-Origin-Embedder-Policy "credentialless" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-store" always;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    http2 on;

    ssl_certificate /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;

    ssl_session_cache shared:SSL:10m;
    ssl_session_timeout 10m;
    ssl_session_tickets off;

    ssl_stapling on;
    ssl_stapling_verify on;
    resolver 1.1.1.1 1.0.0.1 valid=300s;
    resolver_timeout 5s;
}

# ─── REST API — api.${DEPLOY_PRIMARY_DOMAIN} ───
# Serves the dashboard's API + the plugin's HTTP /chat endpoint. Express routes by path.
server {
    server_name api.${DEPLOY_PRIMARY_DOMAIN};

    access_log /var/log/nginx/${DEPLOY_LOG_PREFIX}_api_access.log security;
    error_log /var/log/nginx/${DEPLOY_LOG_PREFIX}_api_error.log warn;

    client_max_body_size 4m;

    add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
    add_header X-Content-Type-Options "nosniff" always;

    location / {
        limit_req zone=api burst=40 nodelay;
        limit_conn conn_limit 20;

        proxy_pass http://clansocket_backend;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header X-Request-ID $request_id;

        proxy_connect_timeout 10s;
        proxy_send_timeout 30s;
        proxy_read_timeout 30s;

        proxy_buffering on;
        proxy_buffer_size 4k;
        proxy_buffers 8 4k;

        proxy_hide_header X-Powered-By;
        proxy_hide_header Server;

        add_header Strict-Transport-Security "max-age=63072000; includeSubDomains; preload" always;
        add_header X-Content-Type-Options "nosniff" always;
        add_header Cross-Origin-Resource-Policy "same-origin" always;
        add_header Cache-Control "no-store" always;
    }

    listen [::]:443 ssl;
    listen 443 ssl;
    http2 on;

    ssl_certificate /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/privkey.pem;
    ssl_trusted_certificate /etc/letsencrypt/live/${DEPLOY_CERT_DOMAIN}/chain.pem;

    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers on;
    ssl_ciphers ECDHE-ECDSA-AES128-GCM-SHA256:ECDHE-RSA-AES128-GCM-SHA256:ECDHE-ECDSA-AES256-GCM-SHA384:ECDHE-RSA-AES256-GCM-SHA384:ECDHE-ECDSA-CHACHA20-POLY1305:ECDHE-RSA-CHACHA20-POLY1305:DHE-RSA-AES128-GCM-SHA256:DHE-RSA-AES256-GCM-SHA384;

    ssl_session_cache shared:SSL:10m;
