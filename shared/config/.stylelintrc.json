{
  "extends": "stylelint-config-standard",
  "plugins": ["stylelint-declaration-strict-value"],
  "rules": {
    "color-no-invalid-hex": true,
    "color-named": "never",
    "color-no-hex": null,

    "declaration-block-no-duplicate-properties": true,
    "declaration-block-no-duplicate-custom-properties": true,
    "declaration-block-no-redundant-longhand-properties": true,
    "declaration-block-no-shorthand-property-overrides": true,
    "declaration-no-important": true,
    "declaration-property-value-no-unknown": true,
    "declaration-empty-line-before": null,

    "font-family-no-duplicate-names": true,
    "font-family-no-missing-generic-family-keyword": true,
    "font-family-name-quotes": "always-where-recommended",
    "font-weight-notation": "numeric",

    "function-calc-no-unspaced-operator": true,
    "function-linear-gradient-no-nonstandard-direction": true,
    "function-no-unknown": true,
    "function-url-no-scheme-relative": true,
    "function-url-quotes": "always",

    "keyframe-block-no-duplicate-selectors": true,
    "keyframe-declaration-no-important": true,
    "keyframes-name-pattern": null,

    "media-feature-name-no-unknown": true,
    "media-feature-name-no-vendor-prefix": true,
    "media-feature-name-value-no-unknown": true,
    "media-query-no-invalid": true,

    "no-duplicate-at-import-rules": true,
    "no-duplicate-selectors": null,
    "no-empty-source": true,
    "no-invalid-double-slash-comments": true,
    "no-invalid-position-at-import-rule": true,
    "no-irregular-whitespace": true,
    "no-unknown-animations": true,
    "no-unknown-custom-media": true,
    "no-unknown-custom-properties": null,

    "property-no-deprecated": true,
    "property-no-unknown": true,
    "property-no-vendor-prefix": true,

    "selector-anb-no-unmatchable": true,
    "selector-attribute-quotes": "always",
    "selector-max-id": 0,
    "selector-max-universal": 2,
    "selector-no-qualifying-type": [true, { "ignore": ["attribute", "class"] }],
    "selector-no-vendor-prefix": true,
    "selector-not-notation": "complex",
    "selector-pseudo-class-no-unknown": true,
    "selector-pseudo-element-no-unknown": true,
    "selector-type-no-unknown": [true, { "ignoreTypes": ["/^[a-z]/"] }],

    "string-no-newline": true,

    "unit-no-unknown": true,
    "unit-disallowed-list": ["px", "pt", "pc", "in", "mm", "cm", "Q"],
    "unit-allowed-list": ["rem", "em", "vw", "vh", "vi", "vb", "dvh", "dvw", "dvi", "dvb", "%", "ms", "s", "deg", "fr", "ch"],

    "value-keyword-case": "lower",
    "value-no-vendor-prefix": true,

    "at-rule-no-deprecated": true,
    "at-rule-no-unknown": [true, { "ignoreAtRules": ["keyframes"] }],
    "at-rule-no-vendor-prefix": true,

    "alpha-value-notation": "number",
    "color-function-alias-notation": "without-alpha",
    "color-function-notation": "modern",
    "color-hex-length": "short",
    "hue-degree-notation": "angle",
    "import-notation": "string",
    "length-zero-no-unit": true,
    "lightness-notation": "percentage",
    "media-feature-range-notation": "context",
    "number-max-precision": 4,
    "shorthand-property-no-redundant-values": true,

    "declaration-block-single-line-max-declarations": 100,
    "selector-class-pattern": null,
    "custom-property-pattern": null,
    "no-descending-specificity": null,

    "declaration-property-unit-allowed-list": {
      "font-size": ["rem", "em", "vw", "vi", "%"],
      "line-height": [],
      "letter-spacing": ["em"],
      "width": ["rem", "em", "%", "vw", "ch"],
      "inline-size": ["rem", "em", "%", "vw", "vi", "ch"],
      "max-width": ["rem", "%", "vw"],
      "max-inline-size": ["rem", "%", "vw", "vi"],
      "min-width": ["rem", "%", "vw"],
      "min-inline-size": ["rem", "%", "vw", "vi"],
      "height": ["rem", "em", "%", "vh", "dvh", "vw"],
      "block-size": ["rem", "em", "%", "vh", "vb", "dvh", "dvb", "vw", "vi"],
      "min-height": ["rem", "%", "vh", "dvh"],
      "min-block-size": ["rem", "%", "vh", "vb", "dvh", "dvb"],
      "max-block-size": ["rem", "%", "vh", "vb", "dvh", "dvb"],
      "gap": ["rem"],
      "padding": ["rem"],
      "padding-inline": ["rem"],
      "padding-block": ["rem"],
      "margin": ["rem"],
      "margin-inline": ["rem", "%"],
      "margin-block": ["rem", "em"],
      "margin-bottom": ["rem", "em"],
      "margin-block-end": ["rem", "em"],
      "margin-top": ["rem", "em"],
      "margin-block-start": ["rem", "em"],
      "border-radius": ["rem", "%"],
      "outline-offset": ["rem"]
    },

    "scale-unlimited/declaration-strict-value": [
      [
        "/^font-size/",
        "/^padding/",
        "/^margin/",
        "/^gap/",
        "/^row-gap$/",
        "/^column-gap$/",
        "/^border-radius/",
        "line-height",
        "letter-spacing",
        "border-width",
        "z-index",
        "opacity",
        "filter",
        "backdrop-filter",
        "box-shadow"
      ],
      {
        "ignoreValues": [
          "0",
          "1",
          "auto",
          "inherit",
          "initial",
          "unset",
          "revert",
          "revert-layer",
          "currentColor",
          "transparent",
          "none"
        ],
        "disableFix": true,
        "message": "Use a token (var(--fs-*|--sp-*|--ls-*|--radius-*|--z-*|--opacity-*|--blur-*|--shadow-*|--icon-*|--clr-warn-*)). If no close neighbor exists in tokens.css, add one there — never inline a raw value in a component."
      }
    ],

    "at-rule-empty-line-before": null,
    "rule-empty-line-before": null,
    "comment-empty-line-before": null
  }
}
